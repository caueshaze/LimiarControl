# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/limiarcontrol

# --- Server ---
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# APP_ENV: "development" or "production". In production, secrets below are REQUIRED.
APP_ENV=development
AUTO_MIGRATE=true

# --- Auth (REQUIRED in production — use a long random string, e.g. `openssl rand -hex 32`) ---
JWT_SECRET=dev-secret-change-me

# --- Centrifugo (REQUIRED in production) ---
CENTRIFUGO_API_URL=http://localhost:8001/api
CENTRIFUGO_API_KEY=dev-api-key
CENTRIFUGO_TOKEN_SECRET=dev-secret-change-me
CENTRIFUGO_PUBLIC_URL=ws://localhost:8001/connection/websocket

# --- Cloudinary (optional — image uploads disabled if empty) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
